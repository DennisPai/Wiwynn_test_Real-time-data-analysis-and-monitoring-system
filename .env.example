# ===== Database =====
# 方式 A：直接給完整 URL（Zeabur / Heroku / Railway 等雲端平台慣例）
# 注意：driver 會自動正規化為 mysql+asyncmy，所以 mysql:// 或 mariadb:// 都接受
# DATABASE_URL=mysql+asyncmy://user:pass@host:3306/dbname

# 方式 B：拆成五個欄位（本機 docker compose 預設走這個）
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=monitoring
DB_USER=app_user
DB_PASSWORD=change_me_in_prod
DB_ROOT_PASSWORD=change_me_root
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ===== JWT =====
# 產生方式：openssl rand -hex 32
JWT_SECRET_KEY=please-generate-with-openssl-rand-hex-32-min-length
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ===== App =====
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8501

# ===== Realtime defaults（首次 alembic 種入 app_settings 表）=====
REALTIME_TICK_SECONDS=1
BATCH_FLUSH_SECONDS=5
ANOMALY_THRESHOLD_HIGH=80.0
ANOMALY_THRESHOLD_LOW=10.0

# ===== Frontend =====
BACKEND_URL=http://backend:8000
BACKEND_WS_URL=ws://backend:8000

# ===== Seed accounts（僅首次 alembic seed 用）=====
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=user123
SEED_VIEWER_EMAIL=viewer@example.com
SEED_VIEWER_PASSWORD=viewer123
