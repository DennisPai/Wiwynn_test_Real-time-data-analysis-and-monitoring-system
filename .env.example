# =============================================================================
# .env.example — 即時資料分析監控系統環境變數範本
#
# 本地開發者只需：
#   1. cp .env.example .env
#   2. 改 JWT_SECRET_KEY（openssl rand -hex 32）與 DB 密碼
#   3. docker compose up -d --build
#   → 三個 service（mariadb / backend / frontend）自動啟動
#
# 注意：docker-compose.yml 已覆寫 BACKEND_URL / BACKEND_WS_URL 為容器間 service name，
#   本地開發不需手動修改這兩個變數。
# =============================================================================


# ===== 【本地部屬預設（推薦）】— 方式 B：拆欄位，docker compose 自動組 DATABASE_URL =====
# docker-compose.yml 的 backend service 會依下列欄位組出完整 DATABASE_URL，
# 並以 DB_HOST=mariadb（compose service name）覆寫 host，確保容器間通訊正確。

DB_HOST=mariadb
DB_PORT=3306
DB_NAME=monitoring
DB_USER=app_user
DB_PASSWORD=change_me_in_prod
DB_ROOT_PASSWORD=change_me_root
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ===== Frontend 連線（本地）=====
# docker-compose.yml 已覆寫為 http://backend:8000 / ws://backend:8000（容器間 service name）。
# 以下為容器外直接開 streamlit（不走 compose）時的本地預設值：
BACKEND_URL=http://localhost:8000
BACKEND_WS_URL=ws://localhost:8000

# Streamlit server port（docker compose 已 expose 8501）
STREAMLIT_SERVER_PORT=8501

# ===== JWT =====
# 產生方式：openssl rand -hex 32
# 正式環境部署前必須替換，長度 < 32 字元時後端啟動直接 raise
JWT_SECRET_KEY=please-generate-with-openssl-rand-hex-32-min-length
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ===== App =====
APP_ENV=development
LOG_LEVEL=INFO

# CORS_ORIGINS：允許的前端來源，逗號分隔可多個
# 本地 docker compose → 保持 http://localhost:8501 即可
# 雲端部署 → 改為前端公開 URL（例如 https://your-frontend.zeabur.app）
CORS_ORIGINS=http://localhost:8501

# ===== Realtime defaults（首次 alembic seed 種入 app_settings 表）=====
REALTIME_TICK_SECONDS=1
BATCH_FLUSH_SECONDS=5
ANOMALY_THRESHOLD_HIGH=80.0
ANOMALY_THRESHOLD_LOW=10.0

# ===== Seed accounts（僅首次 alembic seed 用；正式環境請改密碼）=====
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=user123
SEED_VIEWER_EMAIL=viewer@example.com
SEED_VIEWER_PASSWORD=viewer123


# =============================================================================
# 【雲端部屬選用（Zeabur / Heroku / Railway 等）】— 方式 A：直接給完整 URL
#
# 雲端部署時，將下列設定在平台環境變數後台（不需也不建議將機密寫入此檔）。
# =============================================================================

# --- 後端資料庫 ---
# 取消註解並填入雲端資料庫完整連線字串（mysql:// 或 mariadb:// 開頭皆可，driver 自動補 +asyncmy）：
# DATABASE_URL=mysql+asyncmy://user:pass@host:3306/dbname
#
# 注意：有設 DATABASE_URL 時，上方 DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME 全部忽略。

# --- 後端對外設定 ---
# APP_ENV=production
# LOG_LEVEL=INFO
# JWT_SECRET_KEY=<openssl rand -hex 32 產生的值>
# CORS_ORIGINS=https://your-frontend.zeabur.app

# --- 前端連線（雲端環境必設）---
# 雲端若不設以下兩個變數，前端 fallback 到 localhost:8000，連線必然失敗
# BACKEND_URL=https://your-backend.zeabur.app
# BACKEND_WS_URL=wss://your-backend.zeabur.app
#   注意：雲端 WebSocket 需用 wss://（TLS），本地才用 ws://
